  <!-- Exercise SnappingRadius. With SnapToCellWithClosestPoint on, destination points that
       fall outside every source cell snap to the nearest source cell within SnappingRadius.
       SnappingRadius is honored only when ComputeTolerance is off. MarkBlankPointsAndCells
       blanks un-resampled points, so coloring by the resampled source array V shows the snap
       fill: the destination mesh (can) fills in once snapping is enabled with a large enough
       radius. (Source Data Arrays = disk_out_ref, Destination Mesh = can.) -->
  <pqevent object="pqClientMainWindow/propertiesDock/propertiesPanel/scrollArea/qt_scrollarea_viewport/scrollAreaWidgetContents/PropertiesFrame/ProxyPanel/MarkBlankPointsAndCells/CheckBox" command="set_boolean" arguments="true" />
  <pqevent object="pqClientMainWindow/propertiesDock/propertiesPanel/scrollArea/qt_scrollarea_viewport/scrollAreaWidgetContents/PropertiesFrame/ProxyPanel/SnapToCellWithClosestPoint/CheckBox" command="set_boolean" arguments="true" />
