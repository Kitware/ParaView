<?xml version="1.0" ?>
<pqevents>
  <pqevent object="pqClientMainWindow/menubar" command="activate" arguments="menuSources" />
  <pqevent object="pqClientMainWindow/menubar/menuSources" command="activate" arguments="&amp;Alphabetical" />
  <pqevent object="pqClientMainWindow/menubar/menuSources/Alphabetical" command="activate" arguments="SpatioTemporalHarmonicsSource" />
  <pqevent object="pqClientMainWindow/propertiesDock/propertiesPanel/Accept" command="activate" arguments="" />

  <!-- Use a Surface representation, colored by the time-varying array, so there is
       actual mesh geometry (and per-timestep color texture) to export -->
  <pqevent object="pqClientMainWindow/representationToolbar/displayRepresentation/comboBox" command="set_string" arguments="Surface" />
  <pqevent object="pqClientMainWindow/variableToolbar/displayColor/Variables" command="activated" arguments="SpatioTemporalHarmonics" />

  <!-- export timesteps 5, 7, 9 and 11 by configuring stride at 2 and frame window [5, 11] -->
  <pqevent object="pqClientMainWindow/menubar" command="activate" arguments="menu_File" />
  <pqevent object="pqClientMainWindow/menubar/menu_File" command="activate" arguments="actionExport" />
  <pqevent object="pqClientMainWindow/FileExportDialog" command="filesSelected" arguments="$PARAVIEW_TEST_ROOT/ExportAnimatedUSD.usda" />
  <pqevent object="pqClientMainWindow/ProxyWidgetDialog/scrollArea/qt_scrollarea_viewport/Container/ProxyWidget/WriteTimeSteps/CheckBox" command="set_boolean" arguments="true" />
  <pqevent object="pqClientMainWindow/ProxyWidgetDialog/scrollArea/qt_scrollarea_viewport/Container/ProxyWidget/FrameStride/LineEdit0" command="set_string" arguments="2" />
  <pqevent object="pqClientMainWindow/ProxyWidgetDialog/scrollArea/qt_scrollarea_viewport/Container/ProxyWidget/FrameWindow/LineEdit0" command="set_string" arguments="5" />
  <pqevent object="pqClientMainWindow/ProxyWidgetDialog/scrollArea/qt_scrollarea_viewport/Container/ProxyWidget/FrameWindow/LineEdit1" command="set_string" arguments="11" />

  <pqevent object="pqClientMainWindow/ProxyWidgetDialog/widget/OKButton" command="activate" arguments="" />

  <!-- export timesteps 13 and 15 from Python -->
  <pqevent object="pqClientMainWindow/menubar" command="activate" arguments="menu_View" />
  <pqevent object="pqClientMainWindow/menubar/menu_View" command="activate" arguments="Python Shell" />
  <pqevent object="pqClientMainWindow/pythonShellDock/pythonShell/consoleWidget" command="executeCommand" arguments="renderView1 = GetActiveViewOrCreate('RenderView')" />
  <pqevent object="pqClientMainWindow/pythonShellDock/pythonShell/consoleWidget" command="executeCommand" arguments="ExportView('$PARAVIEW_TEST_ROOT/ExportAnimatedUSD.usda', view=renderView1, WriteTimeSteps=1, FrameStride=2, FrameWindow=[13, 15])" />

</pqevents>
