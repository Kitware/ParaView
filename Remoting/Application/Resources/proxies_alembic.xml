<ServerManagerConfiguration>
  <ProxyGroup name="exporters_internal">
    <RenderViewExporterProxy class="vtkAlembicExporter"
                             name="AlembicExporter">
      <Documentation>Exporter to export a single render view to Alembic scene format.
      </Documentation>
      <StringVectorProperty command="SetFileName"
                            name="FileName"
                            panel_visibility="never"
                            number_of_elements="1">
        <Documentation>Name of the file to be written.</Documentation>
      </StringVectorProperty>
      <Hints>
        <ExporterFactory extensions="abc" />
      </Hints>
      <!-- End of AlembicExporter -->
    </RenderViewExporterProxy>
  </ProxyGroup>

  <ProxyGroup name="exporters">
    <AnimatedExporterProxy name="AlembicExporter" processes="client" class="vtkSMAnimationSceneSeriesWriter">

      <StringVectorProperty command="SetFileName"
                            name="FileName"
                            panel_visibility="never"
                            number_of_elements="1">
        <Documentation>Name of the file to be written.</Documentation>
      </StringVectorProperty>

      <SubProxy>
        <Proxy name="Exporter" proxygroup="exporters_internal" proxyname="AlembicExporter" />
      </SubProxy>

      <IntVectorProperty
        name="WriteTimeSteps"
        command="SetWriteTimeSteps"
        default_values="0"
        number_of_elements="1">
        <BooleanDomain name="bool"/>
      </IntVectorProperty>

      <ProxyProperty name="AnimationScene" command="SetAnimationScene" panel_visibility="never" />

      <IntVectorProperty name="FrameStride"
                         number_of_elements="1"
                         command="SetStride"
                         default_values="1"
                         panel_visibility="advanced">
        <IntRangeDomain name="range" min="1"/>
        <FrameStrideQueryDomain name="query">
          <RequiredProperties>
            <Property name="AnimationScene" function="AnimationScene" />
          </RequiredProperties>
        </FrameStrideQueryDomain>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="enabled_state"
                                   property="WriteTimeSteps"
                                   value="1" />
        </Hints>
        <Documentation>
          The stride which is used to extract the next frame.
          E.g. 1, 2, 3, would have frame stride = 1, while 1, 3, 5 would have frame stride = 2.
        </Documentation>
      </IntVectorProperty>

      <IntVectorProperty name="FrameWindow"
        number_of_elements="2"
        default_values="none"
        command="SetFrameWindow"
        panel_visibility="advanced">
        <AnimationFrameWindowDomain name="range" default_mode="min,max">
          <RequiredProperties>
            <Property name="AnimationScene" function="AnimationScene" />
          </RequiredProperties>
        </AnimationFrameWindowDomain>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="enabled_state"
                                   property="WriteTimeSteps"
                                   value="1" />
        </Hints>
        <Documentation>
          Specify a timestep window to save only a part of the animation.
        </Documentation>
      </IntVectorProperty>

      <Hints>
        <ExporterFactory extensions="abc" />
      </Hints>
    </AnimatedExporterProxy>
  </ProxyGroup>

</ServerManagerConfiguration>
